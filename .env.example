# ===== CRM ติดตามลูกค้าขาดฝาก — ตัวอย่างไฟล์ตั้งค่า =====
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง:  cp .env.example .env
# ⚠️ ห้าม commit ไฟล์ .env (อยู่ใน .gitignore แล้ว)

# ----- จำเป็น -----
# ฐานข้อมูล (dev ใช้ SQLite ในเครื่อง / prod แนะนำ PostgreSQL)
DATABASE_URL="file:./dev.db"

# กุญแจเซ็น JWT session — สุ่มให้ยาวและเดายาก เช่น `openssl rand -base64 32`
SESSION_SECRET="เปลี่ยนเป็นค่าสุ่มยาวๆ"

# ----- ไม่บังคับ (มีค่าเริ่มต้น/ทำงานโหมด mock ถ้าไม่ใส่) -----
# โหมด dev: แสดงรหัส OTP บนหน้าจอแทนการส่งจริง (1 = เปิด)
OTP_DEV_MODE="1"

# แจ้งเตือน Telegram — สร้างบอทจาก @BotFather (ไม่ใส่ = ไม่ส่งจริง โหมด mock)
TELEGRAM_BOT_TOKEN=""

# กุญแจป้องกัน endpoint cron (/api/cron/*) — ใช้กับ crontab/launchd/Vercel Cron
CRON_SECRET="เปลี่ยนเป็นค่าสุ่ม"
# โดเมนฐานที่สคริปต์ cron จะยิงเข้า (เครื่อง dev = http://localhost:3000)
# CRON_BASE_URL="https://your-domain.com"

# เกตเวย์ส่ง SMS — ไม่ใส่ = โหมด mock (ไม่ส่งจริง)
SMS_GATEWAY_URL=""
SMS_GATEWAY_KEY=""
SMS_SENDER="CRM"
